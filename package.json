{
  "name": "object-storage",
  "version": "1.0.0",
  "description": "Standalone object storage server with Node.js + Express + TypeScript",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "node -e \"require('fs').cpSync('src/db/schema.sql', 'dist/db/schema.sql')\"",
    "start": "node dist/server.js",
    "test": "tsx tests/e2e.test.ts"
  },
  "keywords": ["object-storage", "file-storage", "express", "typescript"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.7",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/sqlite3": "^3.1.11",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  }
}
